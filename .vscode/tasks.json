{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Build",
      "command": ["make", "build"],
      "group": {
        "kind": "build",
        "isDefault": true,
        "problemMatcher": "$gcc"
      },
      "presentation": {
        "echo": true,
        "reveal": "never",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
