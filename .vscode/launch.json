  "version": "0.2.0",
  "configurations": [
    {
      "name": "Test",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/test-forge",
      "args": [
        "--gtest_catch_exceptions=0",
        "--gtest_filter=*integration_pure_math_neg.simple_u8"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "MIMode": "lldb",
      "preLaunchTask": "Build",
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
