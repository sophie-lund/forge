{
  "editor.formatOnSave": true,
  "editor.rulers": [80],
  "C_Cpp.default.cStandard": "c23",
  "C_Cpp.default.cppStandard": "c++23",
  "cSpell.words": [
    "Cloners",
    "DCMAKE",
    "fsanitize",
    "gtest",
    "rtti",
    "syntaxtree",
    "termcolor",
    "Wextra"
  ],
  "files.associations": {
